<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="department_filter_inherit" model="ir.ui.view">
        <field name="name">department.filter.inherit</field>
        <field name="model">account.asset</field>
        <field name="inherit_id" ref="account_asset.view_account_asset_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search/group[1]" position="inside">
                <filter name="group_by_department" string="Department" domain="[]" context="{'group_by': 'department_info'}" />
            </xpath>
        </field>
    </record>

</odoo>
