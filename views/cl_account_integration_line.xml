<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="cl_account_integration_line_tree_view" model="ir.ui.view">
        <field name="name">cl.account.integration.line.tree.view</field>
        <field name="model">cl.account.integration.line</field>
        <field name="arch" type="xml">
            <tree string="CL Account Integration Line Tree View">
                <field name="account_id" />
                <field name="account_name_id" />
                <field name="mapping_code_id" />
                <field name="mapping_name_id" />
            </tree>
        </field>
    </record>

    <record id="cl_account_integration_line_form_view" model="ir.ui.view">
        <field name="name">cl.account.integration.line.form.view</field>
        <field name="model">cl.account.integration.line</field>
        <field name="arch" type="xml">
            <form string="CL Account Integration Line Form View">
                <sheet>
                    <group>
                        <group>
                            <field name="account_id" />
                            <field name="account_name_id" />
                        </group>
                        <group>
                            <field name="mapping_code_id" />
                            <field name="mapping_name_id" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
